# Copy this file to .env and fill in your local Postgres credentials
DATABASE_URL="postgresql://<username>:<password>@localhost:5432/<database_name>"
PORT=5000
GEMINI_API_KEY="your Gemini API key here"
GITHUB_TOKEN="your PAT token here"
REDIS_HOST=localhost
REDIS_PORT=6379
SECURITY_AGENT_URL=http://localhost:5001
DATABASE_AGENT_URL=http://localhost:5000
GITHUB_WEBHOOK_SECRET=<run ${node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"}>